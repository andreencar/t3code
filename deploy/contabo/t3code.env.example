# Copy this file to /opt/t3code/shared/t3code.env on the VPS.

# Generate with: openssl rand -hex 24
T3CODE_AUTH_TOKEN=replace-me

# Optional overrides.
T3CODE_PORT=3773
T3CODE_HOME=/opt/t3code/shared/data
T3CODE_LOG_LEVEL=info

# Uncomment to bind to a fixed address instead of the Tailscale IPv4.
# T3CODE_HOST=100.x.y.z
